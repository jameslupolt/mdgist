{
  "unstable": ["kv", "cron"],
  "tasks": {
    "flags": "deno run --allow-env --allow-net --unstable-kv --unstable-cron --allow-read",
    "start": "deno task flags main.ts",
    "debug": "deno task flags --inspect-brk main.ts",
    "dev": "deno task flags --watch main.ts"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "lz": "https://esm.sh/lz-string@1.5.0",
    "marked": "https://esm.sh/marked@17.0.4",
    "xss": "https://esm.sh/xss@1.0.15",
    "highlight.js": "https://esm.sh/highlight.js@11.11.1"
  },
  "lint": {
    "include": [
      "*.ts"
    ],
    "exclude": [
      "lib/",
      "static/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "no-unused-vars"
      ]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": [
      "*.ts"
    ],
    "exclude": [
      "lib/",
      "static/",
      "templates.ts"
    ]
  }
}
